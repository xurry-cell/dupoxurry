rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidMemory(incomingData) {
      return incomingData.keys().hasAll(['title', 'date', 'mediaUrls', 'mediaType', 'userId', 'createdAt', 'author']) &&
        incomingData.title is string && incomingData.title.size() <= 200 &&
        incomingData.date is string && incomingData.date.size() <= 50 &&
        incomingData.mediaUrls is list && incomingData.mediaUrls.size() <= 20 &&
        (incomingData.mediaUrls.size() == 0 || incomingData.mediaUrls[0] is string) &&
        incomingData.mediaType is string && incomingData.mediaType.matches('^(image|video)$') &&
        incomingData.userId == 'guest-user' &&
        incomingData.author in ['duPO', 'xurry'] &&
        incomingData.createdAt is timestamp &&
        (
          !('musicUrl' in incomingData) || 
          (incomingData.musicUrl is string && incomingData.musicUrl.size() <= 1048487)
        ) &&
        (
          !('updatedAt' in incomingData) || 
          (incomingData.updatedAt is timestamp)
        ) &&
        (
          !('songTitle' in incomingData) || 
          (incomingData.songTitle is string && incomingData.songTitle.size() <= 200)
        ) &&
        (
          !('note' in incomingData) || 
          (incomingData.note is string && incomingData.note.size() <= 5000)
        );
    }

    function isValidPersonalPhoto(incomingData) {
      return incomingData.keys().hasAll(['category', 'imageUrl', 'createdAt']) &&
        incomingData.category is string && incomingData.category.matches('^(dupo|xurry)$') &&
        incomingData.imageUrl is string && incomingData.imageUrl.size() <= 1048487 &&
        incomingData.createdAt is timestamp &&
        (
          !('title' in incomingData) || 
          (incomingData.title is string && incomingData.title.size() <= 200)
        );
    }
    
    function hasValidCreateKeys(incomingData) {
      let baseKeys = ['title', 'date', 'mediaUrls', 'mediaType', 'userId', 'createdAt', 'author'];
      let isMusicSent = 'musicUrl' in incomingData;
      let isUpdatedAtSent = 'updatedAt' in incomingData;
      let isSongTitleSent = 'songTitle' in incomingData;
      let isNoteSent = 'note' in incomingData;
      let expectedSize = 7 + (isMusicSent ? 1 : 0) + (isUpdatedAtSent ? 1 : 0) + (isSongTitleSent ? 1 : 0) + (isNoteSent ? 1 : 0);
      
      return incomingData.keys().hasAll(baseKeys) && incomingData.keys().size() == expectedSize;
    }
    
    function hasValidPhotoCreateKeys(incomingData) {
      let baseKeys = ['category', 'imageUrl', 'createdAt'];
      let isTitleSent = 'title' in incomingData;
      let expectedSize = 3 + (isTitleSent ? 1 : 0);
      return incomingData.keys().hasAll(baseKeys) && incomingData.keys().size() == expectedSize;
    }

    function isValidSettings(incomingData) {
      return (!('dupoCover' in incomingData) || (incomingData.dupoCover is string && incomingData.dupoCover.size() <= 1048487)) &&
             (!('xurryCover' in incomingData) || (incomingData.xurryCover is string && incomingData.xurryCover.size() <= 1048487));
    }

    match /system/{doc} {
      allow get: if true;
    }

    match /settings/{docId} {
      allow get: if true;
      allow read, write: if true;
    }
    
    match /personal_photos/{photoId} {
      allow get: if isValidId(photoId);
      allow list: if true;
      allow create: if isValidId(photoId) &&
        isValidPersonalPhoto(incoming()) &&
        hasValidPhotoCreateKeys(incoming()) &&
        incoming().createdAt == request.time;
      allow update: if false; // No updates for simplicity, just delete and recreate
      allow delete: if isValidId(photoId);
    }
    
    match /memories/{memoryId} {
      allow get: if isValidId(memoryId);
      allow list: if true;
      
      allow create: if isValidId(memoryId) &&
        isValidMemory(incoming()) &&
        hasValidCreateKeys(incoming()) &&
        incoming().createdAt == request.time;
        
      allow update: if isValidId(memoryId) &&
        isValidMemory(incoming()) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'date', 'mediaUrls', 'mediaType', 'musicUrl', 'updatedAt', 'author', 'songTitle', 'note']) &&
        incoming().userId == existing().userId &&
        incoming().createdAt == existing().createdAt &&
        incoming().updatedAt == request.time;
        
      allow delete: if isValidId(memoryId) && existing().userId == 'guest-user';
    }
  }
}
